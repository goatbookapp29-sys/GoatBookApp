{
  "expo": {
    "name": "GoatBook",
    "slug": "GoatBook",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "newArchEnabled": true
    },
    "android": {
      "package": "com.goatwala.farm",
      "newArchEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/splash-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your farm profile and animals.",
          "cameraPermission": "The app accesses your camera to let you take photos of your livestock and profile."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "fbdd2a91-3947-442f-b555-79a7f85473d9"
      }
    },
    "owner": "ayush20001"
  }
}
